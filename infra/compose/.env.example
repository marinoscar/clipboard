# =============================================================================
# Clipboard Application - Environment Variables
# =============================================================================

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:8320

# Database (SQLite - file path inside container)
DATABASE_URL=file:/data/clipboard.db

# JWT Authentication
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8320/api/auth/google/callback

# AWS S3 Storage
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Admin Bootstrap (first user with this email becomes admin)
INITIAL_ADMIN_EMAIL=admin@example.com

# Logging
LOG_LEVEL=info
